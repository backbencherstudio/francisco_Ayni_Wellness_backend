# =========================
# App / Server
# =========================
NODE_ENV=development
PORT=4000
APP_NAME=Ayni Wellness
APP_URL=http://localhost:4000
CLIENT_APP_URL=http://localhost:3000
APP_KEY=change_me

# =========================
# Database (Prisma/Postgres)
# =========================
DATABASE_URL=postgresql://postgres:root@localhost:5432/backend

# =========================
# Redis
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# =========================
# JWT
# =========================
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRY=3600s

# =========================
# Mail (SMTP)
# =========================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=

# =========================
# Stripe
# =========================
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Used by plans config
TRIAL_DAYS=14
SUBSCRIPTION_TRIAL_DAYS=14
STRIPE_PRICE_TRIAL=
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=

# =========================
# Mobile Social Login (Flutter)
# =========================
# Google: set at least one of these
GOOGLE_ANDROID_APP_ID=
GOOGLE_IOS_APP_ID=
# Or provide multiple audiences as comma-separated list
GOOGLE_MOBILE_APP_IDS=

# Apple: audience must match what your Flutter app requests
APPLE_CLIENT_ID=
# Optionally allow multiple audiences
APPLE_MOBILE_CLIENT_IDS=

# =========================
# Firebase / Google Cloud Storage (used by FirebaseStorageService)
# =========================
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# IMPORTANT: keep the literal \n in the .env value (the service converts it)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=

# =========================
# AI Routines: YouTube playlist
# =========================
YOUTUBE_API_KEY=
YOUTUBE_PLAYLIST_ID=

# =========================
# Optional Storage (S3 / MinIO)
# If these exist, main.ts will auto-switch SazedStorage to S3 mode.
# =========================
AWS_S3_ENDPOINT=
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_FORCE_PATH_STYLE=true

MINIO_ENDPOINT=
MINIO_BUCKET=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_PORT=9000
MINIO_USE_SSL=false

# =========================
# Support/Feedback routing
# =========================
SYSTEM_USERNAME=system
SYSTEM_EMAIL=
SYSTEM_PASSWORD=
SUPPORT_OWNER_EMAIL=
FEEDBACK_OWNER_EMAIL=
