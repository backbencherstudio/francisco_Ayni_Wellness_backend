# ============================================
# 1. App / Server
# ============================================
NODE_ENV=production
APP_NAME=Ayni Wellness App
APP_KEY=secret
PORT=4001
APP_URL=http://localhost:${PORT}

CLIENT_APP_URL=http://localhost:3000

# ============================================
# 2. SECURITY & AUTHENTICATION
# ============================================
SESSION_SECRET=secret
JWT_SECRET=secret
JWT_EXPIRY=86400000

# ============================================
# 3. DATABASE (PostgreSQL)
# ============================================
DATABASE_URL=postgresql://postgres:root@127.0.0.1:5432/AyniWellness

# ============================================
# 4. REDIS (Cache & Queues)
# ============================================
REDIS_HOST=localhost
REDIS_PASSWORD=
REDIS_PORT=6379

# ============================================
# 5. EMAIL SERVICE (SMTP)
# ============================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=sazedul.bdcalling@gmail.com
MAIL_PASSWORD=pxqaphzdfxpwubwh
MAIL_FROM_ADDRESS=sazedul.bdcalling@gmail.com
MAIL_FROM_NAME="${APP_NAME}"


# ============================================
# 6. ADMIN CREDENTIALS
# ============================================
ADMIN_EMAIL=admin@ayniwellness.com
ADMIN_NAME=Administrator


# =========================
# Subscription (backend trial)
# =========================
